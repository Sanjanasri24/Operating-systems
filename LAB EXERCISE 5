//Non-Preemptive Priority Scheduling
#include <stdio.h>
int main() {
    int p[5],i,j,t,n;
    scanf("%d",&n);
    for(i=0;i<n;i++) scanf("%d",&p[i]);
    for(i=0;i<n-1;i++)
        for(j=i+1;j<n;j++)
            if(p[i]>p[j]){
                t=p[i]; p[i]=p[j]; p[j]=t;
            }
    for(i=0;i<n;i++) printf("%d ",p[i]);
}
