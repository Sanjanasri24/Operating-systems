//Non-Preemptive Priority Scheduling#include <stdio.h>

int main() {
    int n,p[10],pr[10],i,j,t;

    scanf("%d",&n);

    for(i=0;i<n;i++){
        p[i]=i+1;
        scanf("%d",&pr[i]);
    }

    for(i=0;i<n-1;i++)
        for(j=i+1;j<n;j++)
            if(pr[i]>pr[j]){
                t=pr[i]; pr[i]=pr[j]; pr[j]=t;
                t=p[i]; p[i]=p[j]; p[j]=t;
            }

    printf("Execution Order:\n");
    for(i=0;i<n;i++)
        printf("P%d ",p[i]);

    return 0;
}
