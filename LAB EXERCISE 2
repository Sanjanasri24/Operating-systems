//Copy One File to Another
#include <fcntl.h>
#include <unistd.h>

int main()
{
    int s, d, n;
    char buf[100];

    s = open("source.txt", O_RDONLY);
    d = open("dest.txt", O_CREAT | O_WRONLY, 0644);

    while((n = read(s, buf, 100)) > 0)
        write(d, buf, n);

    close(s);
    close(d);

    return 0;
}
