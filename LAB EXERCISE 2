#include <fcntl.h>
#include <unistd.h>
#include <stdio.h>
int main() {
    char ch;
    int s = open("source.txt", O_RDONLY);
    int d = open("copy.txt", O_WRONLY | O_CREAT | O_TRUNC, 0644);
    while (read(s, &ch, 1) > 0)
        write(d, &ch, 1);
    close(s);
    close(d);
    printf("File copied successfully.\n");
    return 0;
}
